; Require dependencies to be at least 7 days old before installing.
; Mitigates supply-chain risk from freshly published malicious versions.
; pnpm (>=10.16): minutes — 7 days = 7 * 24 * 60 = 10080
minimum-release-age=10080
; npm (>=11.6.1): days
min-release-age=7

; Do not run lifecycle scripts (preinstall/install/postinstall) of dependencies.
; Mitigates arbitrary code execution from compromised packages.
; Supported by both npm and pnpm.
ignore-scripts=true

; Pin exact versions when adding/updating dependencies (no ^/~ prefix).
; Reduces supply-chain risk from unexpected version drift.
; Supported by both npm and pnpm.
save-exact=true
