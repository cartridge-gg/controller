{
  "name": "@cartridge/controller",
  "version": "0.13.12",
  "description": "Cartridge Controller",
  "repository": {
    "type": "git",
    "url": "https://github.com/cartridge-gg/controller.git",
    "directory": "packages/controller"
  },
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build:deps": "pnpm build:browser && pnpm build:node",
    "dev": "vite build --watch",
    "build:browser": "vite build",
    "build:styles": "node bin/build-react-styles.mjs",
    "build:node": "tsup --config tsup.node.config.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest",
    "version": "pnpm pkg get version"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./react/styles.css": "./dist/react/styles.css",
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.js"
    },
    "./session/node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js",
      "require": "./dist/node/index.cjs"
    }
  },
  "dependencies": {
    "@cartridge/controller-wasm": "catalog:",
    "@cartridge/penpal": "catalog:",
    "@starknet-io/get-starknet-core": "5.0.0",
    "@starknet-io/types-js": "0.9.1",
    "@turnkey/sdk-browser": "^5.15.2",
    "@wallet-standard/wallet": "^1.1.0",
    "@walletconnect/ethereum-provider": "^2.20.0",
    "bs58": "^6.0.0",
    "cbor-x": "^1.5.0",
    "ethers": "^6.13.5",
    "micro-sol-signer": "^0.5.0",
    "mipd": "^0.0.7",
    "open": "^10.1.0",
    "starknet": "^8.5.2"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cartridge/controller-ui": "workspace:*",
    "@cartridge/tsconfig": "workspace:*",
    "@microsoft/api-extractor": "^7",
    "@types/jest": "catalog:",
    "@types/mocha": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "autoprefixer": "catalog:",
    "jest": "^29.7.0",
    "postcss": "catalog:",
    "prettier": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rollup-plugin-visualizer": "^5.12.0",
    "tailwindcss": "catalog:",
    "ts-jest": "^29.2.5",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "^5.0.3",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vite-plugin-top-level-await": "catalog:",
    "vite-plugin-wasm": "catalog:"
  }
}
